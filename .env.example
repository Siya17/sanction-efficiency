# Copy this file to ".env" (local) or set these in your Vercel project settings.
# All client-exposed values MUST start with VITE_.

VITE_APP_TITLE="Did Sanctions Work? Did Foreign Aid Work? Evidence Lab"
VITE_APP_SUBTITLE="A classroom investigation of sanctions and foreign aid."

# Key used for the local (per-browser) fallback class board.
VITE_BOARD_STORAGE_KEY="did-it-work-evidence-lab-submissions"

# --- Shared, real-time class board (optional) ---
# Set BOTH to turn on the shared board with live case-claiming across groups.
# Leave either blank to fall back to the local per-browser board.
# Find these in your Supabase project: Settings -> API.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
